# Archivos de caché de Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# --- ChromeDriver descargado localmente ---
drivers/
chromedriver*.zip

# Caché de Pytest
.pytest_cache/

# Reporte HTML generado (se regenera en cada ejecución)
reports/reporte.html

# Screenshots de fallos (se regeneran en cada ejecución, excepto el .gitkeep)
reports/screenshots/*.png

# Variables de entorno (pueden contener credenciales sensibles)
.env
.env.local
.env.*.local

# Entornos virtuales de Python
venv/
.venv/
env/
.env/

# Metadatos de paquetes Python
*.egg-info/
dist/
build/
*.egg

# IDEs y editores
.idea/
.vscode/
*.swp
*.swo
*~

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
